<Window x:Class="KeywordOcr.App.MemoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="메모 수정" Width="400" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="메모:" FontSize="12" Foreground="#555" Margin="0,0,0,6"/>
        <TextBox x:Name="MemoBox" Grid.Row="1" FontSize="12" TextWrapping="Wrap"
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="6"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="취소" Width="70" Height="30" Margin="0,0,6,0"
                    Background="#e0e0e0" Foreground="#333" FontSize="12"
                    Click="Cancel_Click"/>
            <Button Content="저장" Width="70" Height="30"
                    Background="#1a1a2e" Foreground="White" FontSize="12"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>

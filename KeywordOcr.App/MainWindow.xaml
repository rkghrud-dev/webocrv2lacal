                                        Click="BrowseTokenPath_Click"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Mall ID"/>
                                <TextBlock x:Name="SettingsMallId" Grid.Row="1" Grid.Column="1" FontSize="11"
                                           Foreground="#1a1a2e" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="토큰 상태"/>
                                <TextBlock x:Name="SettingsTokenStatus" Grid.Row="2" Grid.Column="1" FontSize="11"
                                           Foreground="#888" VerticalAlignment="Center"/>

                                    <Button Content="리프레쉬" Width="72" Height="24"
                                            Background="#457b9d" Foreground="White" FontSize="11"
                                            Style="{StaticResource SmallButton}"
                                            Click="RefreshTokenA_Click"/>
                                    <Button Content="토큰 확인" Width="80" Height="24"
                                            Margin="4,0,0,0" Background="#1a1a2e" Foreground="White" FontSize="11"
                                            Style="{StaticResource SmallButton}"
                                            Click="CheckTokenA_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 준비몰(B마켓) 토큰 설정 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="Cafe24 연결 — 준비몰 (B마켓)" Margin="0,8,0,6"/>
                        <Border Background="White" BorderBrush="#eee" BorderThickness="1" CornerRadius="6"
                                Padding="14,10" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="토큰 파일"/>

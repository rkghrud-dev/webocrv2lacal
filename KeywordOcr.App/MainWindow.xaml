                                    Style="{StaticResource ActionButton}"
                                    Click="RunPipeline_Click" IsEnabled="False"/>
                            <Button x:Name="RunKeywordOnlyButton" Grid.Column="2"
                                    Content="키워드만 생성 (OCR결과 재사용)"
                                    Background="#457b9d" Foreground="White"
                                    Style="{StaticResource ActionButton}"
                                    Click="RunKeywordOnly_Click" IsEnabled="False"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="RunListingOnlyButton" Grid.Column="0"
                                    Content="대표이미지만 생성"
                                    Background="#2d6a4f" Foreground="White"
                                    Style="{StaticResource ActionButton}"
                                    Click="RunListingOnly_Click" IsEnabled="False"/>
                            <Button x:Name="OpenOutputFolderButton" Grid.Column="2"
                                    Content="결과 폴더 열기"
                                    Background="#e0e0e0" Foreground="#333"
                                    Style="{StaticResource ActionButton}"
                                    Click="OpenOutputFolder_Click" IsEnabled="False"/>
                        </Grid>

                        <!-- 결과 파일 -->
                        <Border Background="#f8f9fa" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                                BorderBrush="#eee" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OutputFileText" Grid.Column="0" Text="결과 파일 없음"
                                           FontSize="11" Foreground="#888" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="OpenUploadExcelButton" Grid.Column="1"
                                        Content="업로드용 엑셀 열기" Width="120" Height="28"
                                        Background="#2d6a4f" Foreground="White" FontSize="11"
                                        Style="{StaticResource SmallButton}"
                                        Click="OpenUploadExcel_Click" IsEnabled="False"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- ════════════ TAB: 기존 작업내용 ════════════ -->
            <TabItem x:Name="WorkspaceTab" Header="  기존 작업내용  " FontSize="13" FontWeight="SemiBold">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="130"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="자동저장 작업 ZIP" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="WorkspacePackageFolderText" Text="-" FontSize="11" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="새로고침" Width="78" Height="30"
                                Background="#e0e0e0" Foreground="#333" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceRefresh_Click"/>
                        <Button Grid.Column="3" Content="선택 ZIP 불러오기" Width="118" Height="30"
                                Background="#457b9d" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceLoadSelectedPackage_Click"/>
                        <Button Grid.Column="5" Content="ZIP 직접 선택" Width="98" Height="30"
                                Background="#6c5ce7" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceOpenZip_Click"/>
                        <Button Grid.Column="7" Content="현재 작업 표로 보기" Width="126" Height="30"
                                Background="#2d6a4f" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceLoadCurrent_Click"/>
                    </Grid>

                    <Border Grid.Row="1" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                        <DataGrid x:Name="WorkspacePackageGrid" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" BorderThickness="0"
                                  FontSize="11" SelectionMode="Single"
                                  MouseDoubleClick="WorkspacePackageGrid_DoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="저장일" Binding="{Binding DisplayTime}" Width="115"/>
                                <DataGridTextColumn Header="상품수" Binding="{Binding ProductCount}" Width="65"/>
                                <DataGridTextColumn Header="상품코드" Binding="{Binding DisplayCodes}" Width="190"/>
                                <DataGridTextColumn Header="원본" Binding="{Binding SourceFileName}" Width="160"/>
                                <DataGridTextColumn Header="대표 결과" Binding="{Binding RepresentativeResultFile}" Width="*"/>
                                <DataGridTextColumn Header="ZIP" Binding="{Binding FileName}" Width="190"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,10,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="키워드 수정 표" Style="{StaticResource SectionLabel}"/>
                            <TextBlock x:Name="WorkspaceWorkbookText" Text="엑셀 파일을 불러오면 홈런마켓 3계열 + 준비몰 기존 키워드 컬럼을 표로 표시합니다."
                                       FontSize="11" Foreground="#777" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="수정 저장" Width="90" Height="30"
                                Background="#1a1a2e" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceSaveWorkbook_Click"/>
                        <Button Grid.Column="3" Content="수정 저장 + ZIP 만들기" Width="142" Height="30"
                                Background="#00a884" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceSaveZip_Click"/>
                        <Button Grid.Column="5" Content="작업 폴더 열기" Width="100" Height="30"
                                Background="#e0e0e0" Foreground="#333" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="WorkspaceOpenFolder_Click"/>
                    </Grid>

                    <Border Grid.Row="3" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                        <DataGrid x:Name="WorkspaceKeywordGrid" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" FontSize="11"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Extended">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="105" IsReadOnly="True"/>
                                <DataGridTextColumn Header="업로드" Binding="{Binding UploadStatus}" Width="105" IsReadOnly="True"/>
                                <DataGridTextColumn Header="A 상품명" Binding="{Binding AProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                <DataGridTextColumn Header="A 검색어설정" Binding="{Binding ASearchTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="190"/>
                                <DataGridTextColumn Header="A 검색키워드" Binding="{Binding ASearchKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                <DataGridTextColumn Header="홈런 네이버 상품명" Binding="{Binding HomeNaverProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                <DataGridTextColumn Header="홈런 네이버태그" Binding="{Binding HomeNaverTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                                <DataGridTextColumn Header="홈런 롯데ON 상품명" Binding="{Binding HomeLotteOnProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                <DataGridTextColumn Header="홈런 롯데ON 키워드" Binding="{Binding HomeLotteOnKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                                <DataGridTextColumn Header="홈런 11/ESM 상품명" Binding="{Binding HomeCommonProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                <DataGridTextColumn Header="홈런 11/ESM 키워드" Binding="{Binding HomeCommonKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                                <DataGridTextColumn Header="B 상품명" Binding="{Binding BProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                                <DataGridTextColumn Header="B 검색어설정" Binding="{Binding BSearchTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="190"/>
                                <DataGridTextColumn Header="B 검색키워드" Binding="{Binding BSearchKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                <DataGridTextColumn Header="후보 정확형" Binding="{Binding CandidateExactKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="210"/>
                                <DataGridTextColumn Header="후보 용도형" Binding="{Binding CandidateUseKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="210"/>
                                <DataGridTextColumn Header="후보 확장형" Binding="{Binding CandidateExpandKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="210"/>
                                <DataGridTextColumn Header="검수필요" Binding="{Binding ReviewNeeded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                <DataGridTextColumn Header="검수메모" Binding="{Binding ReviewMemo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock x:Name="WorkspaceStatusText" Grid.Row="4" Text="대기 중"
                               FontSize="11" Foreground="#777" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>


            <!-- ════════════ TAB 2: 실행 이력 ════════════ -->
            <TabItem x:Name="HistoryTab" Header="  실행 이력  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionLabel}"
                                   Text="파이프라인 실행 이력" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="새로고침" Width="70" Height="28"
                                Background="#e0e0e0" Foreground="#333" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="RefreshHistory_Click"/>
                    </Grid>

                    <Border Grid.Row="1" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                        <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" BorderThickness="0"
                                  FontSize="11" SelectionMode="Extended"
                                  CanUserSortColumns="True"
                                  MouseDoubleClick="HistoryGrid_DoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="결과 불러오기" FontWeight="SemiBold" Click="HistoryLoad_Click"/>
                                    <MenuItem Header="이미지 선택" Click="HistoryImageSelect_Click"/>
                                    <MenuItem Header="상품목록 보기" Click="HistoryViewProducts_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Cafe24 상품 엑셀 업로드 (브라우저)" Click="HistoryOpenCafe24Excel_Click"/>
                                    <MenuItem Header="Cafe24 이미지+가격 업로드 (API)" Click="HistoryCafe24Upload_Click"/>
                                    <MenuItem Header="Cafe24 신규상품 등록 (API)" Click="HistoryCafe24Create_Click"/>
                                    <Separator/>
                                    <MenuItem Header="업로드용 엑셀 열기" Click="HistoryOpenExcel_Click"/>
                                    <MenuItem Header="결과 폴더 열기" Click="HistoryOpenFolder_Click"/>
                                    <MenuItem Header="엑셀 경로 복사" Click="HistoryCopyPath_Click"/>
                                    <MenuItem Header="작업 패키지 저장" Click="SaveWorkspacePackage_Click"/>
                                    <Separator/>
                                    <MenuItem Header="메모 수정" Click="HistoryEditMemo_Click"/>
                                    <MenuItem Header="이력 복제" Click="HistoryCopy_Click"/>
                                    <MenuItem Header="삭제" Foreground="#c44536" Click="HistoryDelete_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="✓" Width="30"
                                    Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                                <DataGridTextColumn Header="일시" Binding="{Binding DisplayTime}" Width="90"/>
                                <DataGridTextColumn Header="파일" Binding="{Binding DisplaySource}" Width="160"/>
                                <DataGridTextColumn Header="요약" Binding="{Binding DisplaySummary}" Width="*"/>
                                <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="60"/>
                                <DataGridTextColumn Header="이미지" Binding="{Binding DisplayImageStatus}" Width="70"/>
                                <DataGridTextColumn Header="진행" Binding="{Binding DisplayProgress}" Width="180"/>
                                <DataGridTextColumn Header="메모" Binding="{Binding Memo}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="결과 불러오기" Width="100" Height="32"
                                Background="#1a1a2e" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="HistoryLoad_Click"/>
                        <Button Grid.Column="2" Content="폴더 열기" Width="80" Height="32"
                                Background="#457b9d" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="HistoryOpenFolder_Click"/>
                        <Button Grid.Column="4" Content="복사" Width="60" Height="32"
                                Background="#2d6a4f" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="HistoryCopy_Click"/>
                        <Button Grid.Column="6" Content="메모 수정" Width="80" Height="32"
                                Background="#e0e0e0" Foreground="#333" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="HistoryEditMemo_Click"/>
                        <Button Grid.Column="8" Content="삭제" Width="60" Height="32"
                                Background="#c44536" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="HistoryDelete_Click"/>
                        <!-- 벌크 삭제 영역 (오른쪽 끝) -->
                        <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="70,0,0,0">
                            <Button Content="전체선택" Width="70" Height="32"
                                    Background="#e0e0e0" Foreground="#333" FontSize="11"
                                    Style="{StaticResource SmallButton}"
                                    Click="HistorySelectAll_Click"/>
                            <Button Content="선택삭제" Width="70" Height="32" Margin="4,0,0,0"
                                    Background="#c44536" Foreground="White" FontSize="11"
                                    Style="{StaticResource SmallButton}"
                                    Click="HistoryBulkDelete_Click"/></StackPanel>
                    </Grid>
                </Grid>
            </TabItem>


            <!-- ════════════ TAB 4: Cafe24 업로드 ════════════ -->
            <TabItem x:Name="Cafe24UploadTab" Header="  Cafe24 업로드  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="업로드 설정"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="날짜태그"/>
                            <TextBox x:Name="Cafe24DateTag" Grid.Row="0" Grid.Column="1" Height="26" FontSize="11"
                                     VerticalContentAlignment="Center" Padding="6,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="매칭모드"/>
                            <ComboBox x:Name="Cafe24MatchMode" Grid.Row="0" Grid.Column="4" Height="26" FontSize="11">
                                <ComboBoxItem Content="PREFIX" IsSelected="True"/>
                                <ComboBoxItem Content="CONTAINS"/>
                                <ComboBoxItem Content="EXACT"/>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="대표이미지"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="인덱스:" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="Cafe24MainIdx" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="2" TextAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="추가이미지"/>
                            <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
                                <TextBlock Text="시작:" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox x:Name="Cafe24AddStart" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="3" TextAlignment="Center"/>
                                <TextBlock Text="최대:" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="10,0,4,0"/>
                                <TextBox x:Name="Cafe24AddMax" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="10" TextAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="재시도"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="Cafe24RetryCount" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="1" TextAlignment="Center"/>
                                <TextBlock Text="회 / 간격" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="4,0,4,0"/>
                                <TextBox x:Name="Cafe24RetryDelay" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="1.0" TextAlignment="Center"/>
                                <TextBlock Text="초" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="PREFIX"/>
                            <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal">
                                <TextBox x:Name="Cafe24MatchPrefix" Width="40" Height="24" FontSize="11"
                                         VerticalContentAlignment="Center" Text="20" TextAlignment="Center"/>
                                <TextBlock Text="글자" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- 처리할 상품 선택 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="처리할 상품 선택" Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Cafe24SelectCountText" Grid.Column="0"
                                       FontSize="11" Foreground="#666" VerticalAlignment="Center"
                                       Text="(목록 없음 — 새로고침 클릭)"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="전체선택" Width="64" Height="24" FontSize="11" Margin="0,0,4,0"
                                        Click="Cafe24SelectAll_Click"/>
                                <Button Content="전체해제" Width="64" Height="24" FontSize="11" Margin="0,0,4,0"
                                        Click="Cafe24DeselectAll_Click"/>
                                <Button Content="새로고침" Width="64" Height="24" FontSize="11"
                                        Click="Cafe24RefreshList_Click"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                            <DataGrid x:Name="Cafe24ProductList" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" IsReadOnly="False"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      SelectionMode="Extended" SelectionUnit="FullRow"
                                      FontSize="11" MinHeight="80" MaxHeight="220"
                                      CanUserSortColumns="False"
                                      PreviewMouseLeftButtonDown="Cafe24ProductList_PreviewMouseDown">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="✓" Width="36" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="상품명" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="홈런마켓" Binding="{Binding HomeMarketStatus}" Width="90" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="준비몰" Binding="{Binding ReadyMarketStatus}" Width="90" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- 업로드 실행 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="실행" Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="Cafe24UploadButton" Grid.Column="0"
                                    Content="Cafe24 이미지 + 가격 업로드"
                                    Background="#c44536" Foreground="White"
                                    Style="{StaticResource ActionButton}"
                                    Click="Cafe24Upload_Click" IsEnabled="False"/>
                            <Button x:Name="Cafe24CreateButton" Grid.Column="2"
                                    Content="Cafe24 신규상품 등록"
                                    Background="#e76f51" Foreground="White"
                                    Style="{StaticResource ActionButton}"
                                    Click="Cafe24Create_Click" IsEnabled="False"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="업로드 대상:" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="Cafe24HomeCheckBox"
                                      Content="홈런마켓"
                                      IsChecked="True"
                                      Checked="Cafe24MarketTargetCheck_Changed"
                                      Unchecked="Cafe24MarketTargetCheck_Changed"
                                      Margin="0,0,12,0"/>
                            <CheckBox x:Name="Cafe24ReadyCheckBox"
                                      Content="준비몰"
                                      IsChecked="True"
                                      Checked="Cafe24MarketTargetCheck_Changed"
                                      Unchecked="Cafe24MarketTargetCheck_Changed"/>
                        </StackPanel>

                        <!-- 업로드 결과 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="업로드 결과" Margin="0,4,0,6"/>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                            <DataGrid x:Name="UploadResultGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      FontSize="11" MinHeight="100" MaxHeight="250"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="GS코드" Binding="{Binding Gs}" Width="100"/>
                                    <DataGridTextColumn Header="상품번호" Binding="{Binding ProductNo}" Width="80"/>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="80"/>
                                    <DataGridTextColumn Header="대표이미지" Binding="{Binding MainImage}" Width="120"/>
                                    <DataGridTextColumn Header="추가" Binding="{Binding AddCount}" Width="50"/>
                                    <DataGridTextColumn Header="가격" Binding="{Binding PriceStatus}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="UploadSummaryText" Grid.Column="0" FontSize="11"
                                       Foreground="#888" VerticalAlignment="Center"/>
                            <Button x:Name="OpenUploadLogButton" Grid.Column="1"
                                    Content="업로드 로그 열기" Width="120" Height="28"
                                    Background="#457b9d" Foreground="White" FontSize="11"
                                    Style="{StaticResource SmallButton}"
                                    Click="OpenUploadLog_Click" IsEnabled="False"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- ════════════ 쿠팡 업로드 ════════════ -->
            <TabItem x:Name="CoupangUploadTab" Header="  쿠팡 업로드  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="가공파일 선택"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CoupangSourcePath" Grid.Column="0" Height="28" FontSize="11"
                                     VerticalContentAlignment="Center" Padding="6,0"
                                     AllowDrop="True" PreviewDragOver="CoupangSource_DragOver" Drop="CoupangSource_Drop"/>
                            <Button Grid.Column="1" Content="찾아보기" Width="80" Height="28" Margin="6,0,0,0"
                                    FontSize="11" Click="CoupangBrowseSource_Click"/>
                        </Grid>

                        <!-- 처리할 상품 선택 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="처리할 상품 선택" Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CoupangSelectCountText" Grid.Column="0"
                                       FontSize="11" Foreground="#666" VerticalAlignment="Center"
                                       Text="(파일 선택 후 새로고침 클릭)"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="전체선택" Width="64" Height="24" FontSize="11" Margin="0,0,4,0"
                                        Click="CoupangSelectAll_Click"/>
                                <Button Content="전체해제" Width="64" Height="24" FontSize="11" Margin="0,0,4,0"
                                        Click="CoupangDeselectAll_Click"/>
                                <Button Content="새로고침" Width="64" Height="24" FontSize="11"
                                        Click="CoupangRefreshList_Click"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                            <DataGrid x:Name="CoupangProductList" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" IsReadOnly="False"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      SelectionMode="Extended" SelectionUnit="FullRow"
                                      FontSize="11" MinHeight="80" MaxHeight="220"
                                      CanUserSortColumns="False"
                                      PreviewMouseLeftButtonDown="CoupangProductList_PreviewMouseDown">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="✓" Width="36" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="행" Binding="{Binding RowNum}" Width="40" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="90" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="상품명" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="쿠팡" Binding="{Binding CoupangStatus}" Width="90" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="업로드 설정"/>
                        <Grid Margin="0,0,0,10">
                            <CheckBox x:Name="CoupangDryRun"
                                      Content="DRY RUN (등록하지 않고 미리보기만)" IsChecked="True"
                                      FontSize="11" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- 실행 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="실행" Margin="0,4,0,6"/>
                        <Button x:Name="CoupangUploadButton" Content="쿠팡 업로드 실행"
                                Background="#1565c0" Foreground="White"
                                Style="{StaticResource ActionButton}"
                                Click="CoupangUpload_Click"/>

                        <!-- 결과 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="업로드 결과" Margin="0,10,0,6"/>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                            <DataGrid x:Name="CoupangResultGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      FontSize="11" MinHeight="100" MaxHeight="300"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="행" Binding="{Binding Row}" Width="50"/>
                                    <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100"/>
                                    <DataGridTextColumn Header="카테고리/ID" Binding="{Binding Info}" Width="160"/>
                                    <DataGridTextColumn Header="오류" Binding="{Binding Error}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <TextBlock x:Name="CoupangSummaryText" Margin="0,8,0,0" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- ════════════ TAB 3: 옵션 가격 ════════════ -->
            <TabItem x:Name="PriceOptionsTab" Header="  옵션 가격  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionLabel}" Text="옵션 가격 확인 / 수정"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="GPT 파일 불러오기" Width="140" Height="30"
                                Background="#1a1a2e" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="LoadPriceData_Click"/>
                        <TextBlock x:Name="PriceFileText" Grid.Column="1" FontSize="11" Foreground="#888"
                                   VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="2" Content="가격 재계산" Width="90" Height="30" Margin="0,0,4,0"
                                Background="#457b9d" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="RecalcPrices_Click"/>
                        <Button Grid.Column="3" Content="저장" Width="60" Height="30"
                                Background="#2d6a4f" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}"
                                Click="SavePriceData_Click"/>
                    </Grid>

                    <Border Grid.Row="2" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6">
                        <DataGrid x:Name="PriceGrid" AutoGenerateColumns="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" FontSize="11"
                                  CanUserSortColumns="True" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="30"/>
                                <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="옵션명" Binding="{Binding OptionName}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="공급가" Binding="{Binding SupplyPrice, StringFormat=N0}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="판매가" Binding="{Binding SellingPrice, StringFormat=N0}" Width="80" IsReadOnly="True"/>
                                <DataGridTextColumn Header="추가금액" Binding="{Binding AdditionalAmount, StringFormat=N0}" Width="80"/>
                                <DataGridTextColumn Header="소비자가" Binding="{Binding ConsumerPrice, StringFormat=N0}" Width="80" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="전체선택" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                    Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                    Cursor="Hand" Click="PriceSelectAll_Click"/>
                            <Button Content="전체해제" FontSize="10" Padding="6,2"
                                    Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                    Cursor="Hand" Click="PriceDeselectAll_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="PriceSummaryText" Grid.Column="2" FontSize="11" Foreground="#888"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </TabItem>


            <!-- ════════════ TAB 5: 이미지 선택 ════════════ -->
            <TabItem x:Name="ImageSelectionTab" Header="  대표이미지  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 상단: 파일 정보 + 버튼 -->
                    <Grid Grid.Row="0" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource SectionLabel}"
                                   Text="대표/추가 이미지 선택" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ImageSelectionStatus" Grid.Column="1" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <Button Grid.Column="2" x:Name="LoadImagesButton" Content="이미지 불러오기"
                                Width="120" Height="30" Margin="0,0,4,0"
                                Background="#1a1a2e" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="LoadImages_Click"/>
                        <Button Grid.Column="3" x:Name="SaveImageSelectionButton" Content="선택 저장"
                                Width="80" Height="30"
                                Background="#2d6a4f" Foreground="White" FontSize="11"
                                Style="{StaticResource SmallButton}" Click="SaveImageSelection_Click"/>
                    </Grid>

                    <!-- 파일명/일시 표시 -->
                    <Border Grid.Row="1" Background="#f0f4ff" CornerRadius="4" Padding="8,4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="파일:" FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ImageSourceFileText" FontSize="11" Foreground="#333" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="일시:" FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ImageSourceDateText" FontSize="11" Foreground="#333" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="GS코드:" FontSize="11" FontWeight="SemiBold" Foreground="#555" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ImageGsCountText" FontSize="11" Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 메인: 왼쪽 GS목록 + 오른쪽 A/B 상하 썸네일 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 왼쪽: GS코드 목록 -->
                        <Border Grid.Column="0" Background="White" BorderBrush="#ddd"
                                BorderThickness="1" CornerRadius="6">
                            <ListBox x:Name="ImageGsListBox"
                                     SelectionChanged="ImageGsListBox_SelectionChanged"
                                     FontSize="11" BorderThickness="0"
                                     FontFamily="Consolas, 'D2Coding'"/>
                        </Border>

                        <!-- 오른쪽: A마켓(상) / B마켓(하) 분할 -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- A마켓 헤더 -->
                            <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="4,4,0,0" Padding="8,4">
                                <TextBlock Text="A마켓 (홈런마켓)" FontSize="11" FontWeight="Bold" Foreground="#1565c0"/>
                            </Border>
                            <!-- A마켓 썸네일 -->
                            <Border Grid.Row="1" Background="White" BorderBrush="#2196F3"
                                    BorderThickness="1" CornerRadius="0,0,4,4" Padding="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ThumbnailPanel">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="thumbBorder" Margin="3" Padding="2" CornerRadius="4"
                                                        BorderThickness="3" BorderBrush="#ddd"
                                                        Background="#f8f9fa"
                                                        MouseLeftButtonDown="Thumbnail_LeftClick"
                                                        MouseRightButtonDown="Thumbnail_RightClick"
                                                        Cursor="Hand" ToolTip="좌클릭: A대표 / 우클릭: 추가 / 더블클릭: A대표+다음">
                                                    <StackPanel>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Width="120" Height="120"
                                                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="9" Margin="0,2,0,2"
                                                                   Text="{Binding StatusText}" Foreground="{Binding StatusColor}"/>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMain}" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#2196F3"/>
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAdditional}" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="BorderBrush" Value="#4CAF50"/>
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- B마켓 헤더 -->
                            <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="4,4,0,0" Padding="8,4">
                                <TextBlock Text="B마켓 (준비몰)" FontSize="11" FontWeight="Bold" Foreground="#E65100"/>
                            </Border>
                            <!-- B마켓 썸네일 -->
                            <Border Grid.Row="4" Background="White" BorderBrush="#FF9800"
                                    BorderThickness="1" CornerRadius="0,0,4,4" Padding="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="ThumbnailPanelB">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="thumbBorderB" Margin="3" Padding="2" CornerRadius="4"
                                                        BorderThickness="3" BorderBrush="#ddd"
                                                        Background="#f8f9fa"
                                                        MouseLeftButtonDown="ThumbnailB_LeftClick"
                                                        MouseRightButtonDown="Thumbnail_RightClick"
                                                        Cursor="Hand" ToolTip="좌클릭: B대표 / 우클릭: 추가">
                                                    <StackPanel>
                                                        <Image Source="{Binding Thumbnail}"
                                                               Width="120" Height="120"
                                                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="9" Margin="0,2,0,2"
                                                                   Text="{Binding StatusTextB}" Foreground="{Binding StatusColorB}"/>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMainB}" Value="True">
                                                        <Setter TargetName="thumbBorderB" Property="BorderBrush" Value="#FF9800"/>
                                                        <Setter TargetName="thumbBorderB" Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAdditional}" Value="True">
                                                        <Setter TargetName="thumbBorderB" Property="BorderBrush" Value="#4CAF50"/>
                                                        <Setter TargetName="thumbBorderB" Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 하단: 범례 -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Width="16" Height="16" BorderBrush="#2196F3" BorderThickness="3"
                                CornerRadius="2" Margin="0,0,4,0" Background="#E3F2FD"/>
                        <TextBlock Text="A대표" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Width="16" Height="16" BorderBrush="#FF9800" BorderThickness="3"
                                CornerRadius="2" Margin="0,0,4,0" Background="#FFF3E0"/>
                        <TextBlock Text="B대표" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Width="16" Height="16" BorderBrush="#4CAF50" BorderThickness="3"
                                CornerRadius="2" Margin="0,0,4,0" Background="#E8F5E9"/>
                        <TextBlock Text="추가 (우클릭)" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Width="16" Height="16" BorderBrush="#ddd" BorderThickness="3"
                                CornerRadius="2" Margin="0,0,4,0"/>
                        <TextBlock Text="미선택" FontSize="11" Foreground="#888"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>


            <!-- ════════════ TAB 7: 키워드 피드백 ════════════ -->
            <TabItem x:Name="KeywordFeedbackTab" Header="  키워드 피드백  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="키워드 피드백" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="원본 LLM 엑셀과 사용자가 수정한 엑셀을 비교해서 변경점을 저장하고, Codex CLI에 붙여넣을 누적 프롬프트 명령을 만듭니다."
                                   FontSize="11" Foreground="#777" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="원본 엑셀"/>
                                <TextBox x:Name="FeedbackOriginalPathText" Grid.Row="0" Grid.Column="1" Height="24"
                                         FontSize="11" VerticalContentAlignment="Center" Padding="4,0"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="선택" Width="58" Height="24"
                                        Margin="6,0,0,0" Background="#e0e0e0" FontSize="11"
                                        Style="{StaticResource SmallButton}" Click="FeedbackBrowseOriginal_Click"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="수정 엑셀"/>
                                <TextBox x:Name="FeedbackEditedPathText" Grid.Row="1" Grid.Column="1" Height="24"
                                         FontSize="11" VerticalContentAlignment="Center" Padding="4,0"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="선택" Width="58" Height="24"
                                        Margin="6,0,0,0" Background="#e0e0e0" FontSize="11"
                                        Style="{StaticResource SmallButton}" Click="FeedbackBrowseEdited_Click"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="저장소"/>
                                <TextBox x:Name="FeedbackRootPathText" Grid.Row="2" Grid.Column="1" Height="24"
                                         FontSize="11" VerticalContentAlignment="Center" Padding="4,0"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="열기" Width="58" Height="24"
                                        Margin="6,0,0,0" Background="#e0e0e0" FontSize="11"
                                        Style="{StaticResource SmallButton}" Click="FeedbackOpenRoot_Click"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="변경점 비교" Height="36" Margin="0,0,6,0"
                                    Background="#1a1a2e" Foreground="White"
                                    Style="{StaticResource ActionButton}" Click="FeedbackCompare_Click"/>
                            <Button Grid.Column="1" Content="선택 변경점 저장 / CLI 생성" Height="36" Margin="3,0"
                                    Background="#6c5ce7" Foreground="White"
                                    Style="{StaticResource ActionButton}" Click="FeedbackSaveSession_Click"/>
                            <Button Grid.Column="2" Content="CLI 명령어 복사" Height="36" Margin="6,0,0,0"
                                    Background="#00b894" Foreground="White"
                                    Style="{StaticResource ActionButton}" Click="FeedbackCopyCommand_Click"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="세션 폴더 열기" Height="30" Margin="0,0,6,0"
                                    Background="#e0e0e0" Foreground="#333"
                                    Style="{StaticResource SmallButton}" Click="FeedbackOpenSession_Click"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>

                        <!-- 파일 드래그 앤 드롭 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="파일 선택"/>
                        <Border x:Name="DropZone" Background="White" BorderBrush="#ccc"
                                BorderThickness="2" CornerRadius="8" MinHeight="56" Margin="0,0,0,10"
                                AllowDrop="True" Drop="DropZone_Drop" DragEnter="DropZone_DragEnter"
                                DragLeave="DropZone_DragLeave">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="14,10">
                                    <TextBlock x:Name="DropZoneText"
                                               Text="CSV / Excel 파일을 여기에 드래그하거나 [파일 선택] 클릭"
                                               FontSize="12" Foreground="#888"/>
                                    <TextBlock x:Name="DropZoneFile" Text="" FontSize="11" Foreground="#1a1a2e"
                                               FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="파일 선택" Width="90" Height="34" Margin="0,0,10,0"
                                        Background="#e0e0e0" Foreground="#333" FontSize="12"
                                        Style="{StaticResource SmallButton}" Click="SelectFile_Click"/>
                            </Grid>
                        </Border>

                        <!-- 상품코드 선택 -->
                        <Border x:Name="ProductListPanel" Background="White" BorderBrush="#ddd"
                                BorderThickness="1" CornerRadius="6" Margin="0,0,0,10"
                                Visibility="Collapsed" MaxHeight="220">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="10,6,10,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="처리할 상품 선택" FontSize="11" FontWeight="Bold"
                                               Foreground="#555" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ProductCountText" Grid.Column="1" FontSize="11" Foreground="#888"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Button Grid.Column="2" Content="전체선택" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectAll_Click"/>
                                    <Button Grid.Column="3" Content="전체해제" FontSize="10" Padding="6,2"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="DeselectAll_Click"/>
                                </Grid>
                                <WrapPanel Grid.Row="1" Margin="10,0,10,6">
                                    <Button Content="다음10개" FontSize="10" Padding="7,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending10_Click"/>
                                    <Button Content="다음20개" FontSize="10" Padding="7,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending20_Click"/>
                                    <Button Content="다음30개" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending30_Click"/>
                                    <TextBlock Text="지정:" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox x:Name="SelectPendingCountBox" Text="10" Width="38" Height="22"
                                             FontSize="10" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                                    <Button Content="미완료 선택" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectCustomPending_Click"/>
                                    <Button Content="미완료전체" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectAllPending_Click"/>
                                    <Button Content="완료초기화" FontSize="10" Padding="7,2"
                                            Background="Transparent" BorderBrush="#e0b4b4" BorderThickness="1"
                                            Foreground="#9b3f3f" Cursor="Hand" Click="ResetProductProgress_Click"/>
                                </WrapPanel>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="6,0,6,6">
                                    <ItemsControl x:Name="ProductList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="4,2" FontSize="11"
                                                          Checked="ProductCheck_Changed" Unchecked="ProductCheck_Changed">
                                                    <CheckBox.Content>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Code}" FontWeight="SemiBold"
                                                                       Foreground="#1a1a2e" Width="90"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="#555"
                                                                       TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                                                            <TextBlock Text="{Binding HistoryText}" Foreground="#27ae60"
                                                                       FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </CheckBox.Content>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- 옵션 -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="옵션" Margin="0,4,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="MakeListingCheck" Grid.Column="0" Content="대표이미지 생성 포함"
                                      IsChecked="True" FontSize="12" VerticalAlignment="Center"/>

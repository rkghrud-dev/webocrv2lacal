<Window x:Class="KeywordOcr.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeywordOCR v4" Width="860" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ 헤더 ═══ -->
        <Border DockPanel.Dock="Top" Padding="20,14,20,10" Background="#1a1a2e">
            <StackPanel>
                <TextBlock Text="KeywordOCR v4" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="CSV → 이미지/OCR → 로컬 키워드 → Cafe24 신규등록"
                           FontSize="11" Foreground="#aab" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#ddd" BorderThickness="0,0,0,1">
            <MenuItem Header="화면">
                <MenuItem Header="작업흐름" Tag="BasicRunTab" Click="ShowTab_Click"/>
                <MenuItem Header="기존 작업내용" Tag="WorkspaceTab" Click="ShowTab_Click"/>
                <MenuItem Header="대표이미지" Tag="ImageSelectionTab" Click="ShowTab_Click"/>
                <MenuItem Header="초기세팅" Tag="SettingsTab" Click="ShowTab_Click"/>
            </MenuItem>
            <MenuItem Header="옵션">
                <MenuItem Header="자동실행" Tag="AutoRunTab" Click="ShowTab_Click"/>
                <MenuItem Header="실행 이력" Tag="HistoryTab" Click="ShowTab_Click"/>
                <MenuItem Header="Cafe24 업로드" Tag="Cafe24UploadTab" Click="ShowTab_Click"/>
                <MenuItem Header="쿠팡 업로드" Tag="CoupangUploadTab" Click="ShowTab_Click"/>
                <MenuItem Header="옵션 가격" Tag="PriceOptionsTab" Click="ShowTab_Click"/>
                <MenuItem Header="키워드 피드백" Tag="KeywordFeedbackTab" Click="ShowTab_Click"/>
                <MenuItem Header="키워드 편집기" Tag="KeywordEditorTab" Click="ShowTab_Click"/>
                <MenuItem Header="업로드 이력 (DB)" Tag="UploadHistoryDbTab" Click="ShowTab_Click"/>
                <Separator/>
                <MenuItem Header="전원 옵션">
                    <MenuItem x:Name="PreventSleepMenuItem" Header="작업 중 절전 방지"
                              IsCheckable="True" IsChecked="True" Click="PreventSleepMenu_Click"/>
                    <Separator/>
                    <MenuItem x:Name="PowerActionNoneMenuItem" Header="작업 완료 후 아무것도 안 함"
                              IsCheckable="True" IsChecked="True" Click="PowerActionMenu_Click"/>
                    <MenuItem x:Name="PowerActionCloseAppMenuItem" Header="작업 완료 후 프로그램 종료"
                              IsCheckable="True" Click="PowerActionMenu_Click"/>
                    <MenuItem x:Name="PowerActionSleepMenuItem" Header="작업 완료 후 PC 절전"
                              IsCheckable="True" Click="PowerActionMenu_Click"/>
                    <MenuItem x:Name="PowerActionShutdownMenuItem" Header="작업 완료 후 Windows 종료"
                              IsCheckable="True" Click="PowerActionMenu_Click"/>
                    <Separator/>
                    <MenuItem Header="예약 종료 취소" Click="CancelShutdown_Click"/>
                </MenuItem>
                <MenuItem x:Name="ShutdownAfterWorkQuickMenuItem" Header="작업후 종료"
                          IsCheckable="True" Click="ShutdownAfterWorkQuick_Click"/>
            </MenuItem>
            <MenuItem Header="작업 패키지">
                <MenuItem Header="지난 작업 이어하기" Click="ResumeLastWorkspace_Click"/>
                <MenuItem Header="현재 작업 중단/자동저장" Click="StopAndSaveWork_Click"/>
                <Separator/>
                <MenuItem Header="작업 패키지 저장" Click="SaveWorkspacePackage_Click"/>
                <MenuItem Header="작업 패키지 불러오기" Click="LoadWorkspacePackage_Click"/>
            </MenuItem>
            <MenuItem Header="업데이트" Click="ShowUpdateLog_Click"/>
        </Menu>

        <!-- ═══ 상태바 ═══ -->
        <Grid DockPanel.Dock="Bottom" Margin="20,4,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11" Foreground="#888"
                       VerticalAlignment="Center" Text="대기 중"/>
            <ProgressBar x:Name="ProgressBar" Grid.Column="1" Width="220" Height="8"
                         Minimum="0" Maximum="100" Value="0"
                         Foreground="#1a1a2e" Background="#e0e0e0"/>
        </Grid>

        <!-- ═══ 로그 ═══ -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#ddd" BorderThickness="1"
                CornerRadius="6" Margin="20,0,20,0" Height="160">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="10,6,10,4">
                    <TextBlock Text="로그" FontSize="11" FontWeight="Bold" Foreground="#888"/>
                    <Button Content="지우기" HorizontalAlignment="Right" Padding="6,1"
                            FontSize="10" Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                            Cursor="Hand" Click="ClearLog_Click"/>
                </Grid>
                <TextBox x:Name="LogBlock" Grid.Row="1" IsReadOnly="True"
                         Padding="10,2" FontSize="11"
                         FontFamily="Consolas, 'D2Coding'" TextWrapping="Wrap"
                         Foreground="#333" Background="Transparent" BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"/>
            </Grid>
        </Border>

        <!-- ═══ 탭 영역 ═══ -->
        <TabControl x:Name="MainTabControl" Margin="20,10,20,10" Background="Transparent" BorderBrush="#ddd">


            <!-- ════════════ TAB 1: 기본실행 (OCR Only + LLM 수동) ════════════ -->
            <TabItem x:Name="BasicRunTab" Header="  작업흐름  " FontSize="13" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6"
                                Padding="12,8" Margin="0,0,0,12">
                            <UniformGrid Columns="5">
                                <TextBlock Text="1 CSV 선택" FontSize="11" FontWeight="SemiBold" Foreground="#1a1a2e"/>
                                <TextBlock Text="2 1차 가공" FontSize="11" FontWeight="SemiBold" Foreground="#1a1a2e"/>
                                <TextBlock Text="3 대표이미지" FontSize="11" FontWeight="SemiBold" Foreground="#1a1a2e"/>
                                <TextBlock Text="4 LLM 결과" FontSize="11" FontWeight="SemiBold" Foreground="#1a1a2e"/>
                                <TextBlock Text="5 Cafe24 등록" FontSize="11" FontWeight="SemiBold" Foreground="#1a1a2e"/>
                            </UniformGrid>
                        </Border>

                        <!-- 파일 선택 -->
                        <TextBlock Text="파일 선택" FontSize="13" FontWeight="Bold" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="#ccc"
                                BorderThickness="2" CornerRadius="8" MinHeight="56" Margin="0,0,0,10"
                                AllowDrop="True" Drop="DropZone_Drop" DragEnter="DropZone_DragEnter"
                                DragLeave="DropZone_DragLeave">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="14,10">
                                    <TextBlock Text="선택된 파일:" FontSize="12" Foreground="#888"/>
                                    <TextBlock x:Name="TestDropZoneFile" Text="(파일을 선택하세요)" FontSize="11" Foreground="#1a1a2e"
                                               FontWeight="SemiBold" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="파일 선택" Width="90" Height="34" Margin="0,0,10,0"
                                        Background="#e0e0e0" Foreground="#333" FontSize="12"
                                        Style="{StaticResource SmallButton}" Click="SelectFile_Click"/>
                            </Grid>
                        </Border>

                        <!-- 상품코드 선택 -->
                        <Border x:Name="TestProductListPanel" Background="White" BorderBrush="#ddd"
                                BorderThickness="1" CornerRadius="6" Margin="0,0,0,10"
                                Visibility="Collapsed" MaxHeight="280">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="10,6,10,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="처리할 상품 선택" FontSize="11" FontWeight="Bold"
                                               Foreground="#555" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TestProductCountText" Grid.Column="1" FontSize="11" Foreground="#888"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    <Button Grid.Column="2" Content="전체선택" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectAll_Click"/>
                                    <Button Grid.Column="3" Content="전체해제" FontSize="10" Padding="6,2"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="DeselectAll_Click"/>
                                </Grid>
                                <WrapPanel Grid.Row="1" Margin="10,0,10,6">
                                    <Button Content="다음10개" FontSize="10" Padding="7,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending10_Click"/>
                                    <Button Content="다음20개" FontSize="10" Padding="7,2" Margin="0,0,4,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending20_Click"/>
                                    <Button Content="다음30개" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectNextPending30_Click"/>
                                    <TextBlock Text="지정:" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox x:Name="TestSelectPendingCountBox" Text="10" Width="38" Height="22"
                                             FontSize="10" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                                    <Button Content="미완료 선택" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectCustomPending_Click"/>
                                    <Button Content="미완료전체" FontSize="10" Padding="7,2" Margin="0,0,8,0"
                                            Background="Transparent" BorderBrush="#ccc" BorderThickness="1"
                                            Cursor="Hand" Click="SelectAllPending_Click"/>
                                    <Button Content="완료초기화" FontSize="10" Padding="7,2"
                                            Background="Transparent" BorderBrush="#e0b4b4" BorderThickness="1"
                                            Foreground="#9b3f3f" Cursor="Hand" Click="ResetProductProgress_Click"/>
                                </WrapPanel>
                                <DataGrid x:Name="ProductDataGrid" Grid.Row="2" AutoGenerateColumns="False"
                                          HeadersVisibility="Column" CanUserAddRows="False"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          FontSize="11" Margin="6,0,6,6"
                                          SelectionMode="Extended" SelectionUnit="FullRow">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="&#x2713;" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="36" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="자체상품코드" Binding="{Binding Code}" Width="120" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="#1a1a2e"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="처리일" Binding="{Binding HistoryText}" Width="90" IsReadOnly="True">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#27ae60"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- 1차 가공 -->
                        <TextBlock Text="V5 이미지 CLI 키워드 생성" FontSize="14" FontWeight="Bold" Margin="0,4,0,4"/>
                        <TextBlock FontSize="11" Foreground="#888" Margin="0,0,0,10" TextWrapping="Wrap"
                                   Text="이미지 다운로드/가공 후 상품별 이미지를 Codex CLI에 첨부해 사진을 직접 보고 상품명/검색어설정/검색키워드를 생성합니다."/>

                        <Expander Header="고급 옵션" IsExpanded="False" Margin="0,0,0,8"
                                  FontSize="11" Foreground="#555">
                            <StackPanel Margin="0,8,0,0">
                                <!-- 분할 / 버전 설정 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Codex 분할 단위:" FontSize="11" Foreground="#555"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="TestChunkSizeCombo" Grid.Column="1" Width="80" Height="28" FontSize="11"
                                              SelectedIndex="4">
                                        <ComboBoxItem Content="5개"/>
                                        <ComboBoxItem Content="10개"/>
                                        <ComboBoxItem Content="15개"/>
                                        <ComboBoxItem Content="20개"/>
                                        <ComboBoxItem Content="분할안함"/>
                                    </ComboBox>
                                    <!-- 키워드 버전 (BAK — Codex md에서 관리) -->
                                    <ComboBox x:Name="TestKeywordVersionCombo" Grid.Column="3" Width="90" Height="28" FontSize="11"
                                              SelectedIndex="0" Visibility="Collapsed"
                                              SelectionChanged="KeywordVersionCombo_SelectionChanged">
                                        <ComboBoxItem Content="3.0"/>
                                        <ComboBoxItem Content="2.0"/>
                                        <ComboBoxItem Content="1.0"/>
                                    </ComboBox>
                                    <TextBlock Grid.Column="4" Text="(기본값: 분할안함)" FontSize="10" Foreground="#aaa"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- 병렬 실행 수 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="병렬 실행 수:" FontSize="11" Foreground="#555"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <RadioButton x:Name="Parallel3Radio" Grid.Column="1" Content="3" FontSize="11"
                                                 GroupName="ParallelPreset" Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Checked="ParallelPresetRadio_Checked"/>
                                    <RadioButton x:Name="Parallel5Radio" Grid.Column="2" Content="5" FontSize="11"
                                                 GroupName="ParallelPreset" IsChecked="True" Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Checked="ParallelPresetRadio_Checked"/>
                                    <RadioButton x:Name="Parallel10Radio" Grid.Column="3" Content="10" FontSize="11"
                                                 GroupName="ParallelPreset" Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Checked="ParallelPresetRadio_Checked"/>
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <RadioButton x:Name="ParallelCustomRadio" Content="직접입력:" FontSize="11"
                                                     GroupName="ParallelPreset" Margin="0,0,4,0" VerticalAlignment="Center"
                                                     Checked="ParallelPresetRadio_Checked"/>
                                        <TextBox x:Name="ParallelCustomValue" Width="40" Height="24" FontSize="11"
                                                 Text="5" TextAlignment="Center" VerticalContentAlignment="Center"
                                                 IsEnabled="False" TextChanged="ParallelCustomValue_TextChanged"/>
                                    </StackPanel>
                                </Grid>

                                <!-- OCR 제외 옵션 (BAK — 사용안함) -->
                                <Border x:Name="TestSkipOcrPanel" Visibility="Collapsed">
                                    <StackPanel>
                                        <CheckBox x:Name="TestSkipOcrCheck" Visibility="Collapsed"
                                                  Checked="TestSkipOcrCheck_Changed" Unchecked="TestSkipOcrCheck_Changed"/>
                                        <StackPanel x:Name="TestSkipOcrFolderPanel" Visibility="Collapsed">
                                            <TextBlock x:Name="TestSkipOcrFolderText"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="TestRunOcrOnlyButton" Grid.Column="0"
                                    Content="V5 이미지 CLI 키워드 생성 + Cafe24 자동등록" Height="36"
                                    Background="#159A6B" Foreground="White" FontSize="13" FontWeight="Bold"
                                    Click="TestRunOcrOnly_Click"/>
                            <Button x:Name="LoadPastResultButton" Grid.Column="2"
                                    Content="과거 결과 불러오기" Height="36" Width="140"
                                    Background="#457b9d" Foreground="White" FontSize="12"
                                    Click="LoadPastResult_Click"/>
                            <Button x:Name="TestOpenOutputButton" Grid.Column="4"
                                    Content="결과 폴더" Height="36" Width="90"
                                    Background="#dfe6e9" Foreground="#333" FontSize="12"
                                    Click="TestOpenOutput_Click" IsEnabled="False"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,-4,0,10">
                            <CheckBox x:Name="V5AutoCafe24CreateCheckBox"
                                      Content="키워드 생성 완료 후 Cafe24 신규등록까지 자동 실행"
                                      IsChecked="True"
                                      FontSize="11"
                                      FontWeight="SemiBold"
                                      Foreground="#159A6B"/>
                            <TextBlock Text="  ※ 네이버/쿠팡/롯데ON API 업로드와 11번가/ESM 엑셀 생성은 다음 단계에서 실행"
                                       FontSize="10" Foreground="#888" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border x:Name="TestCodexProgressPanel" Background="#eef3f7" CornerRadius="6"
                                Padding="12,8" Margin="0,0,0,8" Visibility="Collapsed"
                                BorderBrush="#dde5ec" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TestCodexProgressText" Grid.Row="0"
                                           Text="Codex 진행 대기" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1a1a2e" TextWrapping="Wrap"/>
                                <ProgressBar x:Name="TestCodexProgressBar" Grid.Row="1" Height="10"
                                             Minimum="0" Maximum="100" Value="0" Margin="0,7,0,5"
                                             Foreground="#1a1a2e" Background="#d9e2ea"/>
                                <TextBlock x:Name="TestCodexProgressDetailText" Grid.Row="2"
                                           Text="" FontSize="11" Foreground="#667"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- 결과 경로 표시 -->
                        <Border Background="#f8f9fa" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                                BorderBrush="#eee" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="TestOutputPathText" Text="결과 폴더: (미실행)"
                                           FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TestSkillMdPathText" Text=""
                                           FontSize="11" Foreground="#6c5ce7" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Codex 병렬 실행 명령어 -->
                        <Border x:Name="TestCodexCmdPanel" Background="#1e1e2e" CornerRadius="6" Padding="12,10"
                                Margin="0,0,0,16" BorderBrush="#6c5ce7" BorderThickness="1" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="TestCodexCmdTitle" Text="" FontSize="12" FontWeight="Bold"
                                           Foreground="#a29bfe" Margin="0,0,0,4"/>

                                <!-- 병렬 실행 설정 -->
                                <Border Background="#17172a" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>

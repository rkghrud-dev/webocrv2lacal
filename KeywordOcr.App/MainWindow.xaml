                                    Click="TestLoadLlmResult_Click"/>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="TestCafe24CreateButton" Grid.Column="0" Grid.ColumnSpan="3"
                                    Content="신규등록 목록 다시 불러오기" Height="36"
                                    Background="#2d6a4f" Foreground="White" FontSize="13" FontWeight="Bold"
                                    Click="TestCafe24Create_Click" IsEnabled="False"/>
                            <Button x:Name="TestCafe24UploadButton" Grid.Column="2"
                                    Content="Cafe24 이미지+가격 업로드" Height="36"
                                    Background="#c44536" Foreground="White" FontSize="13" FontWeight="Bold"
                                    Click="TestCafe24Upload_Click" IsEnabled="False" Visibility="Collapsed"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,4">

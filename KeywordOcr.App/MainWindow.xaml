                                    <CheckBox x:Name="SettingsAutoContrast" Content="자동대비" IsChecked="True"
                                              FontSize="11" Margin="0,0,12,0"/>
                                    <CheckBox x:Name="SettingsSharpen" Content="샤프닝" IsChecked="True"
                                              FontSize="11" Margin="0,0,12,0"/>
                                    <CheckBox x:Name="SettingsSmallRotate" Content="미세회전" IsChecked="True"
                                              FontSize="11" Margin="0,0,12,0"/>
                                    <CheckBox x:Name="SettingsFlipLR" Content="좌우반전" IsChecked="True"
                                              FontSize="11"/>
                                </StackPanel>

                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="상세태그 A"/>
                                <TextBox x:Name="SettingsImgTag" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4"
                                         Height="24" FontSize="11" VerticalContentAlignment="Center" Padding="4,0"
                                         Text="&lt;img src='https://gi.esmplus.com/rkghrud/1.jpg' /&gt;"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="상세태그 B"/>
                                <TextBox x:Name="SettingsImgTagB" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="4"
                                         Height="24" FontSize="11" VerticalContentAlignment="Center" Padding="4,0"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="A 상품명"/>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SettingsLogoPathB" Grid.Column="0" Height="24" FontSize="11"
                                             VerticalContentAlignment="Center" Padding="4,0"/>

                                    <TextBox x:Name="SettingsJpegMin" Width="40" Height="22" FontSize="11"
                                             Text="88" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                    <TextBlock Text=" ~ " FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                    <TextBox x:Name="SettingsJpegMax" Width="40" Height="22" FontSize="11"
                                             Text="92" TextAlignment="Center" VerticalContentAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="회전 줌"/>
                                <TextBox x:Name="SettingsRotateZoom" Grid.Row="3" Grid.Column="4" Width="60"
                                         Height="22" FontSize="11" Text="1.04" TextAlignment="Center"

                                      IsChecked="True"
                                      FontSize="11" FontWeight="SemiBold"
                                      Foreground="#1565c0"
                                      Margin="0,0,12,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="단독 업로드:" FontSize="11" Foreground="#666" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="DirectNaverUploadCheckBox"
                                      Content="네이버"
                                      IsChecked="True"
                                      Margin="0,0,12,0"/>
                            <CheckBox x:Name="DirectLotteOnUploadCheckBox"
                                      Content="롯데ON"
                                      IsChecked="True"
                                      Margin="0,0,12,0"/>
                            <CheckBox x:Name="DirectCoupangUploadCheckBox"
                                      Content="쿠팡"
                                      IsChecked="True"
                                      Margin="0,0,12,0"/>
                            <Button x:Name="DirectHomeMarketUploadButton"
                                    Content="선택 API만 등록"
                                    Height="24"
                                    Padding="8,0"
                                    FontSize="11"
                                    Click="BasicDirectHomeMarketUpload_Click"
                                    IsEnabled="False"/>
                        </StackPanel>

                        <Rectangle Fill="#ccc" Height="1" Margin="0,12,0,8"/>
                        <TextBlock Text="마켓별 엑셀 다운로드" FontSize="12" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,4"/>
                        <TextBlock Text="선택된 상품만 11번가 XLS와 ESM 업로드 엑셀로 생성합니다."
                                   FontSize="11" Foreground="#888" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ExportElevenstExcelButton" Grid.Column="0"
                                    Content="11번가 XLS 생성" Height="30"
                                    Background="#6c757d" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                    Click="ExportElevenstExcel_Click" IsEnabled="False"/>
                            <Button x:Name="ExportEsmExcelButton" Grid.Column="2"
                                    Content="ESM 엑셀 생성" Height="30"
                                    Background="#6c757d" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                    Click="ExportEsmExcel_Click" IsEnabled="False"/>
                            <Button x:Name="ExportAllMarketExcelButton" Grid.Column="4"
                                    Content="둘 다 생성" Height="30"
                                    Background="#1d3557" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                    Click="ExportAllMarketExcel_Click" IsEnabled="False"/>
                            <Button x:Name="OpenMarketExcelFolderButton" Grid.Column="6"
                                    Content="출력 폴더" Height="30" Padding="10,0"
                                    FontSize="11"
                                    Click="OpenMarketExcelFolder_Click" IsEnabled="False"/>
                        </Grid>
                        <TextBlock x:Name="MarketExcelExportStatusText"
                                   Text="엑셀 다운로드: V5 결과 파일 선택 후 사용 가능"
                                   FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,2"/>

                        <!-- ──── Cafe24 신규등록 대상 목록 ──── -->
                        <Rectangle Fill="#ccc" Height="1" Margin="0,12,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="신규등록 대상 목록" FontSize="12" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BasicCafe24CountText" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="8,0,0,0" Text="(파일 선택 후 목록 표시)"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Content="전체선택" Height="24" Padding="8,0" FontSize="11"
                                    Click="BasicCafe24SelectAll_Click" Margin="0,0,4,0"/>
                            <Button Content="전체해제" Height="24" Padding="8,0" FontSize="11"
                                    Click="BasicCafe24DeselectAll_Click" Margin="0,0,4,0"/>
                            <Button Content="새로고침" Height="24" Padding="8,0" FontSize="11"
                                    Click="BasicCafe24Refresh_Click"/>
                        </StackPanel>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
                            <DataGrid x:Name="BasicCafe24ProductGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      FontSize="11" MinHeight="60" MaxHeight="200"
                                      PreviewMouseLeftButtonDown="BasicCafe24ProductList_PreviewMouseDown">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}" Width="36" IsReadOnly="False"/>
                                    <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="110" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="상품명" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="홈런마켓" Binding="{Binding HomeMarketStatus}" Width="80" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="준비몰" Binding="{Binding ReadyMarketStatus}" Width="80" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Button x:Name="BasicCafe24RunButton"
                                Content="Cafe24 신규등록 실행" Height="36"
                                Background="#2d6a4f" Foreground="White" FontSize="13" FontWeight="Bold"
                                Click="BasicCafe24Run_Click" IsEnabled="False" Margin="0,0,0,8"/>

                        <!-- ──── 마켓 업로드 ──── -->
                        <Rectangle Fill="#ccc" Height="1" Margin="0,4,0,8" Visibility="Collapsed"/>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="마켓 업로드" Margin="0,4,0,6" Visibility="Collapsed"/>
                        <TextBlock Text="Cafe24 신규등록 완료 후, 아래 마켓 업로드 버튼으로 각 마켓에 등록합니다."
                                   FontSize="11" Foreground="#888" Margin="0,0,0,8" Visibility="Collapsed"/>

                        <Grid Margin="0,0,0,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="시작 행"/>
                            <TextBox x:Name="MarketRowStart" Grid.Column="1" Height="26" FontSize="11"
                                     VerticalContentAlignment="Center" Text="0" TextAlignment="Center"
                                     ToolTip="0이면 전체 행"/>
                            <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="끝 행"/>
                            <TextBox x:Name="MarketRowEnd" Grid.Column="4" Height="26" FontSize="11"
                                     VerticalContentAlignment="Center" Text="0" TextAlignment="Center"/>
                        </Grid>
                        <CheckBox x:Name="MarketDryRun" Content="DRY RUN (등록하지 않고 미리보기만)"
                                  Visibility="Collapsed"
                                  IsChecked="True" FontSize="11" Margin="0,0,0,8"/>

                        <Grid Margin="0,4,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="TestCoupangUploadButton" Grid.Column="0"
                                    Content="쿠팡 업로드" Height="36"
                                    Background="#1565c0" Foreground="White" FontSize="13" FontWeight="Bold"
                                    Click="TestCoupangUpload_Click" IsEnabled="False"/>
                            <Button x:Name="TestNaverUploadButton" Grid.Column="2"
                                    Content="네이버 스마트스토어 업로드" Height="36"
                                    Background="#03c75a" Foreground="White" FontSize="13" FontWeight="Bold"
                                    Click="TestNaverUpload_Click" IsEnabled="False"/>
                        </Grid>

                        <!-- 마켓 업로드 결과 -->
                        <TextBlock x:Name="MarketUploadSummary" Margin="0,8,0,4" FontSize="11"
                                   Visibility="Collapsed"
                                   Foreground="#555" TextWrapping="Wrap"/>
                        <Border Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,8" Visibility="Collapsed">
                            <DataGrid x:Name="MarketUploadResultGrid" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      FontSize="11" MinHeight="80" MaxHeight="260"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="마켓" Binding="{Binding Market}" Width="80"/>
                                    <DataGridTextColumn Header="행" Binding="{Binding Row}" Width="50"/>
                                    <DataGridTextColumn Header="상품명" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="90"/>
                                    <DataGridTextColumn Header="정보" Binding="{Binding Info}" Width="140"/>
                                    <DataGridTextColumn Header="오류" Binding="{Binding Error}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- ════════════ TAB 2: 자동실행 ════════════ -->

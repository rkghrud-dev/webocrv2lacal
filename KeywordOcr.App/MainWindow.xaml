                                      Content="홈런마켓"
                                      IsChecked="True"
                                      Checked="Cafe24MarketTargetCheck_Changed"
                                      Unchecked="Cafe24MarketTargetCheck_Changed"
                                      Margin="0,0,12,0"/>
                            <CheckBox x:Name="TestCafe24ReadyCheckBox"
                                      Content="준비몰"
                                      IsChecked="True"
                                      Checked="Cafe24MarketTargetCheck_Changed"
                                      Unchecked="Cafe24MarketTargetCheck_Changed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <CheckBox x:Name="AutoNaverLotteOnCheckBox"

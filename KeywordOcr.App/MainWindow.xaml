                        <Border Background="#f8f8ff" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6"
                                Padding="10,8" Margin="0,0,0,10">
                            <TextBlock x:Name="FeedbackStatusText" FontSize="11" Foreground="#555" TextWrapping="Wrap"
                                       Text="원본 엑셀과 수정 엑셀을 선택한 뒤 변경점 비교를 실행하세요."/>
                        </Border>

                        <DataGrid x:Name="KeywordFeedbackGrid" AutoGenerateColumns="False" Height="360"
                                  CanUserAddRows="False" IsReadOnly="False" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  FontSize="11" Background="White" BorderBrush="#ddd" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="반영" Binding="{Binding IncludeInPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52"/>
                                <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn Header="시트" Binding="{Binding SheetName}" Width="86" IsReadOnly="True"/>
                                <DataGridTextColumn Header="컬럼" Binding="{Binding ColumnName}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn Header="변경 전" Binding="{Binding BeforeValue}" Width="2*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="변경 후" Binding="{Binding AfterValue}" Width="2*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>


            <!-- ════════════ TAB: 키워드 편집기 ════════════ -->
            <TabItem x:Name="KeywordEditorTab" Header="  키워드 편집  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="키워드 편집기" FontSize="14" FontWeight="Bold"
                                   Foreground="#1a1a2e" VerticalAlignment="Center"/>
                        <TextBlock x:Name="KeywordEditorStatus" Grid.Column="1" FontSize="11"
                                   Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Button Grid.Column="2" Content="변경사항 저장" Height="32" Width="120"
                                Background="#2d6a4f" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                Style="{StaticResource SmallButton}" Click="KeywordEditorSave_Click" Margin="0,0,8,0"/>
                        <Button Grid.Column="3" Content="변경 분석 → Codex" Height="32" Width="140"
                                Background="#6c5ce7" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                Style="{StaticResource SmallButton}" Click="KeywordEditorAnalyze_Click"/>
                    </Grid>

                    <TextBlock Grid.Row="1" FontSize="11" Foreground="#777" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="마켓별 키워드를 원본과 비교하며 수정합니다. 저장 후 변경 패턴을 분석해 Codex 프롬프트 업데이트에 활용됩니다."/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="KeywordEditorPanel"/>
                    </ScrollViewer>

                    <Border Grid.Row="3" Background="#f0f4ff" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                        <TextBlock x:Name="KeywordEditorAnalysisText" FontSize="11" Foreground="#555"
                                   TextWrapping="Wrap" Text="변경사항을 저장하면 분석 결과가 여기에 표시됩니다."/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ TAB: 업로드 이력 ════════════ -->
            <TabItem x:Name="UploadHistoryDbTab" Header="  업로드 이력  " FontSize="13" FontWeight="SemiBold" Visibility="Collapsed">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="업로드 이력 (DB)" FontSize="14" FontWeight="Bold"
                                   Foreground="#1a1a2e" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="새로고침" Height="28" Width="80" FontSize="11"
                                    Background="#e0e0e0" Foreground="#333"
                                    Style="{StaticResource SmallButton}" Click="UploadHistoryRefresh_Click" Margin="0,0,6,0"/>
                            <Button Content="엑셀 내보내기" Height="28" Width="100" FontSize="11"
                                    Background="#457b9d" Foreground="White"
                                    Style="{StaticResource SmallButton}" Click="UploadHistoryExport_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="날짜:" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="UploadHistoryDateFilter" Grid.Column="1" Height="26" FontSize="11"
                                 VerticalContentAlignment="Center" Text="" ToolTip="예: 2026-05-09"/>
                        <TextBlock Grid.Column="2" Text="마켓:" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <ComboBox x:Name="UploadHistoryMarketFilter" Grid.Column="3" Height="26" FontSize="11">
                            <ComboBoxItem Content="전체" IsSelected="True"/>
                            <ComboBoxItem Content="Cafe24"/>
                            <ComboBoxItem Content="네이버"/>
                            <ComboBoxItem Content="롯데ON"/>
                            <ComboBoxItem Content="쿠팡"/>
                        </ComboBox>
                        <TextBlock Grid.Column="4" Text="GS코드:" FontSize="11" Foreground="#555"
                                   VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <TextBox x:Name="UploadHistoryGsFilter" Grid.Column="5" Height="26" FontSize="11"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="6" Content="검색" Height="26" Width="60" FontSize="11" Margin="8,0,0,0"
                                Background="#1a1a2e" Foreground="White"
                                Style="{StaticResource SmallButton}" Click="UploadHistorySearch_Click"/>
                    </Grid>

                    <DataGrid x:Name="UploadHistoryGrid" Grid.Row="2" AutoGenerateColumns="False"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal" BorderBrush="#ddd" BorderThickness="1"
                              FontSize="11" Background="White"
                              CanUserSortColumns="True" SelectionMode="Single">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="삭제" Click="UploadHistoryDelete_Click" Foreground="#c44536"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="날짜" Binding="{Binding UploadedAt}" Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="GS코드" Binding="{Binding GsCode}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="상품명" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="마켓" Binding="{Binding Market}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="상품ID" Binding="{Binding ProductId}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="오류" Binding="{Binding Error}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="Foreground" Value="#c44536"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ════════════ TAB 8: 설정 ════════════ -->
            <TabItem x:Name="SettingsTab" Header="  초기세팅  " FontSize="13" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel>


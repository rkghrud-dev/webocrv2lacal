<Window x:Class="KeywordOcr.App.Cafe24AuthCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cafe24 다시 인증" Width="640" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip" Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="13" FontWeight="SemiBold" Foreground="#1a1a2e"
                   Text="브라우저에서 Cafe24 로그인 후, callback URL 전체 또는 code 값만 붙여넣으세요."/>
        <TextBlock Grid.Row="1" Margin="0,6,0,10" FontSize="11" Foreground="#666"
                   Text="브라우저 자동 열기가 실패해도 아래 URL 복사 또는 브라우저 열기 버튼으로 다시 진행할 수 있습니다."/>

        <Border Grid.Row="2" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="인증 URL" FontSize="11" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="AuthorizeUrlBox" Grid.Row="1" FontSize="11" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         MinHeight="84" Padding="8" Background="#FAFAFA" BorderBrush="#E6E6E6"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="URL 복사" Width="90" Height="28" Margin="0,0,6,0"
                            Background="#e0e0e0" Foreground="#333" FontSize="11"
                            Click="CopyUrl_Click"/>
                    <Button Content="브라우저 열기" Width="100" Height="28"
                            Background="#1a1a2e" Foreground="White" FontSize="11"
                            Click="OpenBrowser_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="0,12,0,0" Background="White" BorderBrush="#ddd" BorderThickness="1" CornerRadius="6" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Callback URL 또는 code" FontSize="11" Foreground="#555" Margin="0,0,0,6"/>
                <TextBox x:Name="CodeBox" Grid.Row="1" FontSize="12" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         MinHeight="92" Padding="8"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Width="80" Height="30" Margin="0,0,6,0"
                    Background="#e0e0e0" Foreground="#333" FontSize="12"
                    Click="Cancel_Click"/>
            <Button Content="인증 완료" Width="90" Height="30"
                    Background="#c44536" Foreground="White" FontSize="12"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>